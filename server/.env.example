# MongoDB connection string (required). Never expose this in the frontend.
# Example: mongodb://localhost:27017/nur_ramadan or MongoDB Atlas URI
MONGODB_URI=

# Google OAuth Client ID: set VITE_GOOGLE_CLIENT_ID in the *root* .env (shared with frontend).
# The server loads root .env and uses that; no need to duplicate here.
VITE_GOOGLE_CLIENT_ID=

# Port (default 4000)
PORT=4000

# Optional: CORS origin for the frontend (default *). Set to your frontend URL in production, e.g. https://yourdomain.com
# CORS_ORIGIN=
