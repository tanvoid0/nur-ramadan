# Gemini API key (optional; for user-triggered AI)
GEMINI_API_KEY=

# Google OAuth Client ID (required for sign-in)
VITE_GOOGLE_CLIENT_ID=

# Optional: backend API base URL. When set, user data (profile, habits, Quran, recipes) is synced to your server; the app still uses the browser cache (IndexedDB) first for fast UX. Example: http://localhost:4000 or https://api.yourdomain.com. The backend must validate the Google ID token (see server/).
VITE_API_URL=
