{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install && cd server && npm install",
  "rewrites": [
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/[[...path]].js": {
      "runtime": "@vercel/node@3"
    }
  }
}
